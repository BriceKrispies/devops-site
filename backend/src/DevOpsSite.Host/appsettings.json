{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Auth": {
    "Mode": "Oidc",
    "ActivePersona": "viewer",
    "Authority": "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_pq81gvbKF",
    "ClientId": "<app-client-id>"
  },
  "DynamoDb": {
    "UsersTableName": "<users-table-name>",
    "RolesTableName": "<roles-table-name>",
    "Region": "us-east-1",
    "TimeoutMs": 5000
  },
  "ServiceHealth": {
    "BaseUrl": "https://health-api.example.com",
    "TimeoutMs": 5000,
    "MaxRetries": 2
  },
  "Jira": {
    "BaseUrl": "https://jira.example.com",
    "CredentialsRef": "jira-api-token",
    "TimeoutMs": 10000,
    "MaxRetries": 2
  },
  "TraceStore": {
    "Provider": "InMemory"
  }
}
